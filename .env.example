APP_NAME=thai-2d-api
ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./thai_2d.db
DATABASE_PATH=/var/lib/thai-2d/thai_2d.sqlite3
ADMIN_API_KEY=replace-with-a-long-random-secret
COLLECTOR_ENABLED=true
COLLECTOR_INTERVAL_SECONDS=60
STALE_AFTER_SECONDS=86400
ALLOWED_ORIGINS=
SET_JSON_URL=https://www.set.or.th/api/set/index/SET/overview
SET_PAGE_URL=https://www.set.or.th/en/market/index/set/overview
SET_REQUEST_TIMEOUT_SECONDS=15
SET_MAX_RETRIES=3
SET_USER_AGENT=thai-2d-api/1.0 (public market-data collector)
PLAYWRIGHT_FALLBACK_ENABLED=false
PLAYWRIGHT_HEADLESS=true
# No 2D formula is assumed. Add a reviewed strategy before changing this.
# Leave blank until explicit digit positions have been approved.
TWO_D_STRATEGY=
INDEX_DIGIT_POSITION=
VALUE_DIGIT_POSITION=

# Scheduled Myanmar result collection (Asia/Yangon)
MORNING_TARGET=12:01
EVENING_TARGET=16:30
FETCH_INTERVAL_SECONDS=30
MORNING_WINDOW_START=11:59:30
MORNING_WINDOW_END=12:02:00
EVENING_WINDOW_START=16:28:30
EVENING_WINDOW_END=16:32:00
HEADLESS=true
PLAYWRIGHT_BROWSERS_PATH=/opt/thai-2d-api/.cache/ms-playwright
